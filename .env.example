JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=your-api-token

# Workspace: bind-mount a local directory (leave WORKSPACE_REPO_URL empty)
WORKSPACE_PATH=/path/to/your/workspace
WORKSPACE_REPO_URL=
GITHUB_TOKEN=

DATASETTE_PORT=8011
DASHBOARD_PORT=5174

# CXDB context store
CXDB_URL=http://cxdb:80
CXDB_HTTP_PORT=9010
CXDB_BINARY_PORT=9009

# S3 transcript store
TRANSCRIPT_S3_BUCKET=gastown-transcripts
TRANSCRIPT_S3_REGION=us-east-2
